# Flask
SECRET_KEY=change-me-long-random-string
# Optional: SQLite path for persistent DB (Railway volume)
# DATABASE_PATH=/data/fastpost.db

# Stripe (https://dashboard.stripe.com/)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# Owner admin UI (/admin) — must match signed-up user email exactly
ADMIN_EMAIL=

# Optional: public URL for OAuth and Stripe redirects
# PUBLIC_APP_URL=https://your-domain.com

# Optional: legacy migration assigns orphan rows to this user
# MIGRATION_LEGACY_EMAIL=legacy@fastpost.local

# Password reset emails (SMTP). If unset, reset links are logged only.
# SendGrid: MAIL_SERVER=smtp.sendgrid.net MAIL_PORT=587 MAIL_USERNAME=apikey MAIL_PASSWORD=<API_KEY>
# MAIL_DEFAULT_SENDER=FastPost <no-reply@yourdomain.com>
# MAIL_SERVER=
# MAIL_PORT=587
# MAIL_USE_TLS=1
# MAIL_USE_SSL=0
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=
