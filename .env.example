# FastPost Social v3 — copy to backend/.env and edit (optional).
# No third-party API keys are required. Do not commit real .env files.

# --- Flask (optional) ---
# SECRET_KEY=change-me-for-production-session-signing

# --- Paths (optional; defaults work for local dev) ---
# DATABASE_PATH=fastpost.db
# PROFILES_DIR=./browser_profiles

# --- Playwright / deploy (optional) ---
# PLAYWRIGHT_BROWSERS_PATH=/app/.playwright-browsers

# --- Server / posting timeouts (optional) ---
# FLASK_DEBUG=0
# FLASK_RELOADER=0
# POST_TIMEOUT_SECONDS=1200
# GUNICORN_TIMEOUT=1200
# PORT=5000

# --- Stealth poster (optional) ---
# FB_HEADED=0
# FB_LEAVE_BROWSER_OPEN=1
# FB_TZ=America/New_York
# FB_LOGIN_WAIT_SECONDS=900
# FB_LOGIN_TOPUP_SECONDS=480
# FB_PAGE_SETTLE_SECONDS=15
# FB_LOGIN_STABLE_POLLS=4
